# ── Server ────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# A long random string — protects all admin endpoints
# Generate one with: openssl rand -hex 32
ADMIN_SECRET=change-this-to-a-long-random-string

# ── Puppeteer ─────────────────────────────────────────────
# Set automatically in Docker — leave as-is
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# ── Email notifications (Nodemailer) ──────────────────────
# Gmail: enable 2FA, then create an App Password at
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=EuroSpace Hub <your@gmail.com>

# ── Webhook (optional — Discord or Slack) ─────────────────
# Discord: Server Settings → Integrations → Webhooks
WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── Cloudflare Tunnel ─────────────────────────────────────
# Get this from Cloudflare Zero Trust dashboard when creating the tunnel
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here
