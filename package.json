{
  "name": "eurospace-student-hub",
  "version": "1.0.0",
  "description": "Resource directory for European aerospace/space students",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:frontend\"",
    "dev:server": "node --watch server/index.js",
    "dev:frontend": "cd frontend && npx vite",
    "build": "cd frontend && npx vite build",
    "start": "node server/index.js",
    "scrape:now": "node server/scraper.js --run-once",
    "sync:members": "node server/scraper.js --sync-members",
    "docker:up": "docker-compose up -d --build",
    "docker:down": "docker-compose down"
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "fs-extra": "^11.2.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.14",
    "puppeteer": "^22.12.1",
    "winston": "^3.13.0"
  }
}
